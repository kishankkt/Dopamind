{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "DopaMind",
  "version": "0.1.12",
  "identifier": "com.dopamind.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "plugins": {
    "deep-link": {
      "schemes": ["dopamind"]
    },
    "updater": {
      "endpoints": [
        "https://raw.githubusercontent.com/kishankkt/Dopamind/main/release.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE3MUI1ODYxMkFDRkZCQUMKUldTcys4OHFZVmdicHcyNEZ4ZGVkNE0zZHFUaHFVRThSUndPbkRmeDNpVEg4dE9vT3UvOWtYc0UK",
      "dialog": false
    }
  },
  "app": {
    "windows": [
      {
        "title": "DopaMind",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
