# DopaMind Tauri Application Environment Variables
# Copy this file to '.env' inside the /app directory and populate your keys.

# --- SUPABASE CONFIGURATION ---
# Retrieve from Project Settings ➡️ API in your Supabase Console
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
